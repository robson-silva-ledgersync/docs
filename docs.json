{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LedgerSync",
  "description": "Connect your users' bank accounts and pull their transactions, statements, and balances through one uniform API.",
  "colors": {
    "primary": "#0891B2",
    "light": "#22D3EE",
    "dark": "#0E7490"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/ledgersync-wordmark.png",
    "dark": "/logo/ledgersync-wordmark.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "guides/quickstart",
              "guides/connect-a-bank",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/connection-lifecycle",
              "guides/webhooks",
              "guides/data-freshness",
              "guides/checks",
              "guides/pagination",
              "guides/errors"
            ]
          },
          {
            "group": "Go live",
            "pages": [
              "guides/testing",
              "guides/going-live"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.yaml"
      },
      {
        "tab": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@ledgersync.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Request access",
      "href": "https://portal.ledgersyncappv2.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "redirects": [
    { "source": "/quickstart", "destination": "/guides/quickstart", "permanent": true },
    { "source": "/connect-a-bank", "destination": "/guides/connect-a-bank", "permanent": true },
    { "source": "/connection-lifecycle", "destination": "/guides/connection-lifecycle", "permanent": true },
    { "source": "/webhooks", "destination": "/guides/webhooks", "permanent": true },
    { "source": "/errors", "destination": "/guides/errors", "permanent": true },
    { "source": "/testing", "destination": "/guides/testing", "permanent": true },
    { "source": "/going-live", "destination": "/guides/going-live", "permanent": true },
    { "source": "/pagination", "destination": "/guides/pagination", "permanent": true }
  ],
  "footer": {
    "socials": {
      "website": "https://ledgersync.com"
    }
  }
}
